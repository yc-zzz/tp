@startuml
actor User
participant ":Ui" as Ui
participant ":Parser" as Parser
participant ":DeleteCommand" as DeleteCommand
participant ":TransactionList" as TransactionList

User -> Ui : enter "delete 2"
Ui -> Parser : parse("delete 2")
Parser --> Ui : DeleteCommand
Ui -> DeleteCommand : execute(list, ui)

alt valid index
    DeleteCommand -> TransactionList : remove(index)
    TransactionList --> DeleteCommand : removed transaction
    DeleteCommand -> Ui : showMessage("Deleted: ...")
else invalid index
    DeleteCommand -> Ui : showMessage("Invalid index")
end
@enduml